{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",

      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm check)",
      "Bash(pnpm prisma generate)",
      "Bash(pnpm prisma migrate dev)",
      "Bash(git diff)",
      "Bash(git status)"
    ],

    "deny": [
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(rm -rf*)",
      "Bash(sudo*)",
      "Bash(curl*|*)",
      "Bash(wget*|*)"
    ]
  }
}
