generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ──────────────────────────────────────────────────────────────────────

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  passwordHash        String
  name                String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt @default(now())
  accounts            UserAccount[]
  settings            UserSetting?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  transactions        Transaction[]
}

model UserSetting {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  //
  currency        String   @default("EUR")
  activeAccount   Account? @relation(fields: [activeAccountId], references: [id], onDelete: SetNull)
  activeAccountId String?
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Account ───────────────────────────────────────────────────────────────────

model Account {
  id               String        @id @default(cuid())
  name             String
  users            UserAccount[]
  transactions     Transaction[]
  categories       Category[]
  activeInSettings UserSetting[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt @default(now())
}

model UserAccount {
  userId    String
  accountId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([userId, accountId])
  @@index([userId])
  @@index([accountId])
}

// ─── Transaction ───────────────────────────────────────────────────────────────

model Transaction {
  id           String          @id @default(cuid())
  amount       Decimal         @db.Decimal(12, 2)
  description  String
  type         TransactionType @default(EXPENSE)
  date         DateTime        @default(now())
  accountId    String
  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categories   Category[]
  createdById  String
  createdBy    User            @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt @default(now())

  @@index([accountId])
  @@index([accountId, date(sort: Desc)])
}

enum TransactionType {
  INCOME
  EXPENSE
}

// ─── Category ──────────────────────────────────────────────────────────────────

model Category {
  id           String        @id @default(cuid())
  name         String
  color        String?
  icon         String?
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt @default(now())

  @@unique([name, accountId])
  @@index([accountId])
}
