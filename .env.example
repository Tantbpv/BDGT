# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://bdgt:bdgt_password@localhost:5432/bdgt"

# JWT — generate strong random secrets for production
JWT_ACCESS_SECRET="change-me-in-production-min-32-chars-aaaaaaaaaa"
JWT_REFRESH_SECRET="change-me-in-production-min-32-chars-bbbbbbbbbb"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Runtime
NODE_ENV="development"
LOG_LEVEL="debug"
